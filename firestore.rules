rules_version = '2';

// ============================================================================
// Règles de sécurité Firestore — Défi Double TC Morgins
//
// Posture choisie : SANS authentification (tournoi amical de club).
// Objectif : sortir du « mode test » (tout ouvert) sans casser l'app ni le
// panneau admin, qui fonctionnent tous deux de façon anonyme.
//
// Ce que ces règles APPORTENT :
//   ✓ Valident la forme et le type de chaque écriture (bloque les documents
//     malformés et les payloads XSS écrits directement en base).
//   ✓ Plafonnent les valeurs numériques (points/étoiles aberrants refusés).
//   ✓ Protègent le hash du code admin : il peut être créé une fois mais PAS
//     écrasé par un inconnu via l'app.
//
// Limite ASSUMÉE (faute d'authentification) :
//   ✗ Un utilisateur technique peut encore, depuis la console de son
//     navigateur, supprimer un document ou modifier des points DANS les
//     bornes autorisées. Les régles ne peuvent pas distinguer ce geste d'une
//     opération admin légitime, car l'admin écrit lui aussi sans identité.
//     Pour fermer cela, la seule petite étape serait d'ajouter Firebase Auth
//     anonyme + un drapeau admin (voir bloc commenté en bas). Acceptable ici.
//
// Déployer :  firebase deploy --only firestore:rules
//   (ou copier-coller dans Console Firebase > Firestore > Règles)
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----
    function isScore(s) {
      return s is string && s.size() <= 10 && s.matches('^[0-9]{1,2}-[0-9]{1,2}$');
    }
    function validScores(sc) {
      return sc is map
        && isScore(sc.set1) && isScore(sc.set2)
        && (!('set3' in sc) || isScore(sc.set3));
    }
    function shortStr(v, maxLen) {
      return v is string && v.size() > 0 && v.size() <= maxLen;
    }

    // ---- ÉQUIPES (adulte) ----
    match /teams/{id} {
      allow read: if true;

      // seed / ajout d'équipe (admin, anonyme)
      allow create: if shortStr(request.resource.data.name, 80)
                    && request.resource.data.cote is number
                    && request.resource.data.cote >= 0 && request.resource.data.cote <= 100
                    && request.resource.data.points is number
                    && request.resource.data.pinHash is string;

      // saisie d'un match (points), recalcul, reset (points:0), changement de PIN
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['points', 'pinHash', 'pinEnc'])
                    && request.resource.data.points is number
                    && request.resource.data.points >= 0
                    && request.resource.data.points <= 100000;

      allow delete: if true; // suppression d'équipe via le panneau admin
    }

    // ---- MATCHS (adulte) ----
    match /matches/{id} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasOnly(
                         ['equipeA','equipeB','vainqueur','scores','pointsA','pointsB','date'])
                    && shortStr(request.resource.data.equipeA, 80)
                    && shortStr(request.resource.data.equipeB, 80)
                    && request.resource.data.vainqueur in ['A','B']
                    && validScores(request.resource.data.scores)
                    && request.resource.data.pointsA is number
                    && request.resource.data.pointsA >= 0 && request.resource.data.pointsA <= 100
                    && request.resource.data.pointsB is number
                    && request.resource.data.pointsB >= 0 && request.resource.data.pointsB <= 100
                    && request.resource.data.date == request.time;

      // édition d'un match via le panneau admin
      allow update: if request.resource.data.vainqueur in ['A','B']
                    && validScores(request.resource.data.scores)
                    && request.resource.data.pointsA is number
                    && request.resource.data.pointsA >= 0 && request.resource.data.pointsA <= 100
                    && request.resource.data.pointsB is number
                    && request.resource.data.pointsB >= 0 && request.resource.data.pointsB <= 100;

      allow delete: if true; // suppression / reset via le panneau admin
    }

    // ---- JOUEURS (junior) ----
    match /juniors/{id} {
      allow read: if true;

      allow create: if shortStr(request.resource.data.name, 80)
                    && request.resource.data.stars is number
                    && (!('green' in request.resource.data) || request.resource.data.green is bool)
                    && request.resource.data.pinHash is string;

      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['stars', 'pinHash', 'pinEnc'])
                    && request.resource.data.stars is number
                    && request.resource.data.stars >= 0
                    && request.resource.data.stars <= 100000;

      allow delete: if true;
    }

    // ---- MATCHS (junior) ----
    match /juniors_matches/{id} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasOnly(
                         ['joueurA','joueurB','vainqueur','scores','starsA','starsB','greenBalls','date'])
                    && shortStr(request.resource.data.joueurA, 80)
                    && shortStr(request.resource.data.joueurB, 80)
                    && request.resource.data.vainqueur in ['A','B']
                    && validScores(request.resource.data.scores)
                    && request.resource.data.starsA is number
                    && request.resource.data.starsA >= 0 && request.resource.data.starsA <= 10
                    && request.resource.data.starsB is number
                    && request.resource.data.starsB >= 0 && request.resource.data.starsB <= 10
                    && request.resource.data.greenBalls is bool
                    && request.resource.data.date == request.time;

      allow update: if request.resource.data.vainqueur in ['A','B']
                    && validScores(request.resource.data.scores)
                    && request.resource.data.starsA is number && request.resource.data.starsA >= 0 && request.resource.data.starsA <= 10
                    && request.resource.data.starsB is number && request.resource.data.starsB >= 0 && request.resource.data.starsB <= 10;

      allow delete: if true;
    }

    // ---- CONFIG (hash du code admin) ----
    match /config/{id} {
      // Le client doit lire ce doc pour vérifier le code admin à la connexion.
      allow read: if true;
      // Création unique (initialisation). On n'autorise PAS l'écrasement :
      // un inconnu ne peut donc pas réinitialiser/voler le code admin via l'app.
      // Pour changer le code admin ensuite, passer par la console Firebase.
      allow create: if request.resource.data.pinHash is string;
      allow update, delete: if false;
    }

    // Tout le reste : refusé.
    match /{document=**} { allow read, write: if false; }
  }
}


// ============================================================================
// POUR PLUS TARD — option avec authentification (si un jour les enjeux montent)
// ----------------------------------------------------------------------------
// Étapes : activer Auth anonyme (visiteurs) + un compte admin avec custom
// claim `admin:true`. On exige alors `request.auth.token.admin == true` sur
// toutes les opérations sensibles (delete, create d'équipe, édition de match,
// config), et `request.auth != null` sur les créations de match. C'est la
// seule façon d'empêcher réellement un inconnu de supprimer/trafiquer la base.
// Voir SECURITY_REVIEW.md (recommandation 2) pour le détail.
// ============================================================================
