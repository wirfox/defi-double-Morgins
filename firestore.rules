rules_version = '2';

// ============================================================================
// Règles de sécurité Firestore — Défi Double TC Morgins
//
// Architecture : un serveur de confiance (Raspberry, via le SDK Admin qui
// contourne ces règles) est le SEUL à écrire/éditer les matchs et à gérer les
// hash de PIN (collection privée `secrets`). Le navigateur ne fait que LIRE,
// plus quelques opérations admin non sensibles (suppression/édition de fiches).
//
// Ce que ça garantit :
//   ✓ Personne ne peut créer ni modifier un match depuis le navigateur
//     (création/édition réservées au serveur, qui vérifie les PINs). Donc
//     impossible de se fabriquer un match gagnant.
//   ✓ Les hash de PIN ne sont jamais lisibles par le navigateur (collection
//     `secrets` interdite) → les PINs ne sont pas crackables.
//   ✓ Les points/étoiles ne sont jamais écrits (déduits des matchs).
//
// Reste possible (assumé, visible/réversible) : un admin (ou un curieux) peut
// supprimer une fiche/un match depuis le navigateur — ça n'attribue pas de
// points, c'est visible et réparable.
//
// Déployer : Console Firebase > Firestore > Règles > coller > Publier.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isScore(s) {
      return s is string && s.size() >= 1 && s.size() <= 12;
    }
    function validScores(sc) {
      return sc is map
        && isScore(sc.set1) && isScore(sc.set2)
        && (!('set3' in sc) || isScore(sc.set3));
    }
    function shortStr(v, maxLen) {
      return v is string && v.size() > 0 && v.size() <= maxLen;
    }

    // ---- ÉQUIPES (adulte) ----
    match /teams/{id} {
      allow read: if true;
      // Création (seed / ajout) : plus de pinHash sur le doc public (il va dans `secrets`).
      allow create: if shortStr(request.resource.data.name, 80)
                    && request.resource.data.cote is number
                    && request.resource.data.cote >= 0 && request.resource.data.cote <= 100
                    && request.resource.data.points is number;
      // Seuls pinEnc (chiffré, sûr) / pin (legacy, supprimé) / pinHash (supprimé) bougent.
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['pinHash', 'pinEnc', 'pin'])
                    && request.resource.data.points == resource.data.points;
      allow delete: if true;
    }

    // ---- MATCHS (adulte) : écriture/édition réservées au serveur ----
    match /matches/{id} {
      allow read: if true;
      allow create: if false;   // seul le serveur (SDK Admin) crée les matchs
      allow update: if false;   // édition via le serveur uniquement
      allow delete: if true;    // suppression / reset depuis le panneau admin
    }

    // ---- JOUEURS (junior) ----
    match /juniors/{id} {
      allow read: if true;
      allow create: if shortStr(request.resource.data.name, 80)
                    && request.resource.data.stars is number
                    && (!('green' in request.resource.data) || request.resource.data.green is bool);
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['pinHash', 'pinEnc', 'pin', 'green'])
                    && request.resource.data.stars == resource.data.stars
                    && (!('green' in request.resource.data) || request.resource.data.green is bool);
      allow delete: if true;
    }

    // ---- MATCHS (junior) : écriture/édition réservées au serveur ----
    match /juniors_matches/{id} {
      allow read: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if true;
    }

    // ---- SECRETS (hash des PINs) : INTERDIT au navigateur ----
    // Seul le serveur (SDK Admin) y accède. Les clients ne peuvent ni lire ni écrire.
    match /secrets/{id} {
      allow read, write: if false;
    }

    // ---- CONFIG ----
    // config/admin : hash du code admin (lu par l'app à la connexion).
    // config/server : URL du serveur Pi, écrite par le serveur (SDK Admin), lue par l'app.
    match /config/{id} {
      allow read: if true;
      allow create: if request.resource.data.pinHash is string; // init du code admin
      allow update, delete: if false;                            // le serveur passe outre via le SDK Admin
    }

    // Tout le reste : refusé.
    match /{document=**} { allow read, write: if false; }
  }
}
